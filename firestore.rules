rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && incoming().fullName is string && incoming().fullName.size() <= 100
        && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'university', 'skills', 'majorProject', 'bio', 'role', 'status', 'isFirstLogin', 'avatarUrl', 'updatedAt'])
        );
    }

    // Swipes collection
    match /swipes/{swipeId} {
      allow create: if isSignedIn() 
        && incoming().fromUid == request.auth.uid
        && isValidId(incoming().toUid);
      allow get: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow list: if isSignedIn() && resource.data.fromUid == request.auth.uid;
    }

    // Matches collection
    match /matches/{matchId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.uids;
      // Creation usually happens via a cloud function or careful relational sync,
      // but for client side matching we'll allow it if the user is one of the pair
      allow create: if isSignedIn() && request.auth.uid in incoming().uids;
    }
  }
}
